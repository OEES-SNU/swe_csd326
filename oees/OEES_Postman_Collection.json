        {
          "name": "TC-ATTEMPT-01 Start attempt on active exam",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.test('Has attemptId', () => pm.expect(res.attemptId).to.be.a('number'));",
            "pm.test('Has questions array', () => pm.expect(res.questions).to.be.an('array'));",
            "pm.test('Has deadline', () => pm.expect(res.deadline).to.be.a('string'));",
            "pm.collectionVariables.set('attemptId', res.attemptId);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/exams/{{examId}}/attempt/start",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }]
