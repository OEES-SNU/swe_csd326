    {
      "name": "4. Instructor — Exams",
      "item": [

        {
          "name": "TC-EXAM-01 Create exam with manual question selection",
          "event": [{ "listen": "test", "script": { "exec": [
            "// FIX: guard missing variables with clear error, then test",
            "const courseId = pm.collectionVariables.get('courseId');",
            "const questionId = pm.collectionVariables.get('questionId');",
            "if (!courseId) throw new Error('courseId missing — fix course creation (TC-ADMIN-COURSE-01)');",
            "if (!questionId) throw new Error('questionId missing — fix question creation (TC-QUESTION-01) and ensure TC-QUESTION-03 does not overwrite it');",
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Exam has id', () => {",
            "  const res = pm.response.json();",
            "  pm.expect(res.id).to.be.a('number');",
            "  pm.collectionVariables.set('examId', res.id);",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/exams",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{instructorToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Mid-term Exam\",\n  \"courseId\": {{courseId}},\n  \"durationMinutes\": 60,\n  \"totalMarks\": 100,\n  \"maxAttempts\": 2,\n  \"passMark\": 50,\n  \"startTime\": \"2026-04-14T09:00:00\",\n  \"endTime\": \"2026-04-14T12:00:00\",\n  \"questionIds\": [{{questionId}}]\n}" }
          }
        },

        {
          "name": "TC-EXAM-02 Create exam with auto-select criteria",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "// FIX: save examId here too, so downstream tests always have it",
            "pm.test('Exam has id', () => {",
            "  const res = pm.response.json();",
            "  pm.expect(res.id).to.be.a('number');",
            "  // Only overwrite examId if TC-EXAM-01 did not already set it",
            "  if (!pm.collectionVariables.get('examId')) {",
            "    pm.collectionVariables.set('examId', res.id);",
            "  }",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/exams",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{instructorToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Auto-select Exam\",\n  \"courseId\": {{courseId}},\n  \"durationMinutes\": 30,\n  \"totalMarks\": 50,\n  \"maxAttempts\": 1,\n  \"passMark\": 25,\n  \"startTime\": \"2026-04-14T09:00:00\",\n  \"endTime\": \"2026-04-14T12:00:00\",\n  \"autoSelect\": {\n    \"unit\": \"Unit1\",\n    \"difficultyLevel\": \"EASY\",\n    \"questionType\": \"MULTIPLE_CHOICE\",\n    \"count\": 5\n  }\n}" }
