{
  "info": {
    "name": "OEES API — swe_csd326 (FIXED)",
    "description": "Manual API tests for the Online Exam & Evaluation System.\n\nSetup:\n1. Start the Spring Boot app (default port 8080)\n2. Run the collection in ORDER — tests are designed to chain variables automatically.\n\nVariables auto-set by tests:\n- studentToken, studentId\n- instructorToken, instructorId\n- adminToken\n- courseId\n- questionId\n- examId\n- attemptId\n- responseId\n",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",          "value": "http://localhost:8080" },
    { "key": "adminToken",       "value": "" },
    { "key": "instructorToken",  "value": "" },
    { "key": "studentToken",     "value": "" },
    { "key": "studentId",        "value": "" },
    { "key": "instructorId",     "value": "" },
    { "key": "courseId",         "value": "" },
    { "key": "examId",           "value": "" },
    { "key": "attemptId",        "value": "" },
    { "key": "questionId",       "value": "" },
    { "key": "responseId",       "value": "" }
  ],
  "item": [

    {
