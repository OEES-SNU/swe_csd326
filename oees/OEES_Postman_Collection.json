      "item": [

        {
          "name": "TC-AUTH-REG-01 Register Student (valid)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Returns JWT', () => { const b = pm.response.json(); pm.expect(b.token).to.be.a('string'); });",
            "pm.test('Role is STUDENT', () => pm.expect(pm.response.json().role).to.eql('STUDENT'));",
            "const b = pm.response.json();",
            "pm.collectionVariables.set('studentToken', b.token);",
            "pm.collectionVariables.set('studentId', b.id);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Alice Student\",\n  \"email\": \"alice_new3@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"STUDENT\"\n}" }
          }
        },

